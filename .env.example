# Vidnary Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Enable work-in-progress routes (dashboard, onboarding, etc.)
# Set to 'true' for local development, omit or set to 'false' for production
NEXT_PUBLIC_ENABLE_WIP_ROUTES=true
